<%= content_for :title, "Locations" %>

<div
  class="relative w-full h-screen"
  data-controller="map-index"
  data-map-index-locations-value="<%= @locations_geojson %>"
>
  <div data-map-index-target="map" class="w-full h-full"></div>

  <div class="absolute top-4 right-4 z-10">
    <%= link_to "New Location", new_location_path,
          class: "bg-white text-gray-800 font-semibold px-4 py-2 rounded-lg shadow hover:bg-gray-100 transition" %>
  </div>
</div>
